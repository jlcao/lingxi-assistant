{
  "name": "lingxi-desktop",
  "version": "0.3.0",
  "description": "Lingxi Agent 终端助手 - V2.0 纯客户端架构",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "Lingxi Team",
    "email": "team@lingxi.com"
  },
  "homepage": "https://github.com/lingxi/lingxi-desktop",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "build:win": "npm run build && npx electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test:e2e": "npx playwright test",
    "test:electron": "npx playwright test --project=electron"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@types/ws": "^8.18.1",
    "axios": "^1.6.2",
    "bufferutil": "^4.1.0",
    "element-plus": "^2.4.4",
    "iconv-lite": "^0.6.3",
    "localforage": "^1.10.0",
    "marked": "^17.0.3",
    "mitt": "^3.0.1",
    "pinia": "^2.1.7",
    "utf-8-validate": "^6.0.6",
    "vue": "^3.3.4",
    "vue-router": "^4.2.5",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "playwright-electron": "^0.5.0",
    "prettier": "^3.1.1",
    "sass": "^1.69.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^1.8.25",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.lingxi.agent",
    "productName": "Lingxi Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/main/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/images/logo_256x256.png",
      "forceCodeSigning": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "src/assets/images/logo_256x256.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/images/logo_256x256.png",
      "category": "Utility",
      "maintainer": "Lingxi Team <team@lingxi.com>"
    }
  }
}